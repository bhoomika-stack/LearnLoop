<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LearnLoop Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>


    <nav>
        <div class="logo">LearnLoop</div>

        <div class="nav-links">
            <a href="/dashboard">Dashboard</a>
            <a href="/profile">Profile</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <section class="dashboard">

        <div class="welcome-card">
            <h1>Welcome Back 👋</h1>
            <p>
                Continue your learning journey and help others grow.
            </p>
        </div>

        <div class="dashboard-grid">

            <div class="dashboard-card">
                <h2>📚 Skills I Teach</h2>
                <p>
                    Share your expertise with the community.
                </p>
                <a href="/addskills">
                    <button class="primary-btn">
                        Add Skill
                    </button>
                </a>
            </div>

            <div class="dashboard-card">
                <h2>🎯 Skills I Want To Learn</h2>
                <p>
                    Explore and discover new skills.
                </p>
                <a href="/browseSkills">
                    <button class="primary-btn">
                        Browse Skills
                    </button>
                </a>
            </div>

            <div class="dashboard-card">
                <h2>🌎 Community Hub</h2>


                <p>
                    Connect with learners, discover mentors,
                    and become part of the LearnLoop community.
                </p>

                <a href="/community">
                    <button class="primary-btn">
                        Explore Community
                    </button>
                </a>


            </div>


            <div class="dashboard-card">
                <h2>👤 My Profile</h2>
                <p>
                    Manage your information and preferences.
                </p>
                <a href="/profile">
                    <button class="primary-btn">
                        Open Profile
                    </button>
                </a>
            </div>
            <div class="dashboard-card">
                <h2>🚪 Logout</h2>

                <p>
                    Securely sign out of your account and end your session.
                </p>

                <a href="/logout">
                    <button class="logout-btn">
                        Logout
                    </button>
                </a>
            </div>

        </div>

    </section>


    <footer class="footer">


        <div class="footer-container">

            <h2 class="footer-logo">LearnLoop</h2>

            <p class="footer-description">
                A skill-sharing platform where learners become teachers
                and teachers become learners.
            </p>

            <div class="footer-links">
                <a href="/">Home</a>
                <a href="/about">About</a>
                <a href="/register">Register</a>
                <a href="/login">Login</a>
            </div>

        </div>

        <div class="footer-bottom">

            <p class="footer-tagline">
                Learn • Teach • Grow Together
            </p>

            <p class="footer-copy">
                © 2026 LearnLoop | Built using Node.js, Express.js, MongoDB Atlas & EJS
            </p>

        </div>


    </footer>


</body>

</html>