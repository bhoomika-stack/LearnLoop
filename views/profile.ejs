<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LearnLoop - Profile</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>


    <nav>
        <div class="logo">LearnLoop</div>

        <div class="nav-links">
            <a href="/dashboard">Dashboard</a>
            <a href="/profile">Profile</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    
<section class="profile-section">

    <div class="profile-card">

        <div class="profile-header">
            <h1>👤 My Profile</h1>
            <p>Your learning identity on LearnLoop</p>
        </div>

        <div class="profile-info">

            <div class="info-box">
                <h3>Username</h3>
                <p><%= user.username %></p>
            </div>

            <div class="info-box">
                <h3>Email</h3>
                <p><%= user.email %></p>
            </div>

        </div>

        <div class="skills-container">

            <!-- Skills I Teach -->
            <div class="skills-card">

                <h2>📚 Skills I Teach</h2>

                <ul class="profile-skills-list">

                    <% allSkills.forEach(skill => { %>

                        <li class="profile-skill-item">

                            <span class="skill-name">
                                <%= skill.skillName %>
                            </span>

                            <div class="skill-actions">

                                <a href="/edit-skill/<%= skill._id %>">
                                    <button type="button" class="edit-btn">
                                        Edit
                                    </button>
                                </a>

                                <form action="/delete-skill/<%= skill._id %>" method="POST">

                                    <button type="submit" class="delete-btn">
                                        Delete
                                    </button>

                                </form>

                            </div>

                        </li>

                    <% }) %>

                </ul>

            </div>

            <!-- Skills I Want To Learn -->
            <div class="skills-card">

                <h2>🎯 Skills I Want To Learn</h2>

                <div class="coming-soon">

                    <p>
                        Learning goals feature coming soon.
                    </p>

                    <span>
                        Add skills you want to learn, discover mentors,
                        and receive personalized recommendations.
                    </span>

                </div>

            </div>

        </div>

    </div>

</section>



    <footer class="footer">


        <div class="footer-container">

            <h2 class="footer-logo">LearnLoop</h2>

            <p class="footer-description">
                A skill-sharing platform where learners become teachers
                and teachers become learners.
            </p>

            <div class="footer-links">
                <a href="/">Home</a>
                <a href="/about">About</a>
                <a href="/register">Register</a>
                <a href="/login">Login</a>
            </div>

        </div>

        <div class="footer-bottom">

            <p class="footer-tagline">
                Learn • Teach • Grow Together
            </p>

            <p class="footer-copy">
                © 2026 LearnLoop | Built using Node.js, Express.js, MongoDB Atlas & EJS
            </p>

        </div>


    </footer>


</body>

</html>