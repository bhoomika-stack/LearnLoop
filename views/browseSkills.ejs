<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Skills</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>


    <nav>
        <div class="logo">LearnLoop</div>

        <div class="nav-links">
            <a href="/dashboard">Dashboard</a>
            <a href="/profile">Profile</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <section class="browse-skills">

        <div class="page-heading">
            <h1>Browse Skills</h1>
            <p>
                Discover skills shared by the LearnLoop community.
            </p>
        </div>

        <div class="skills-grid">

    <% allSkills.forEach(function(skill) { %>

        <div class="skill-card">

            <h2><%= skill.skillName %></h2>

            <p><%= skill.description %></p>

            <span>
                Category: <%= skill.category %>
            </span>

            <div class="skill-actions">

                <a href="/edit-skill/<%= skill._id %>">
                    <button type="button" class="edit-btn">
                        Edit Skill
                    </button>
                </a>

                <form action="/delete-skill/<%= skill._id %>" method="POST">

                    <button type="submit" class="delete-btn">
                        Delete Skill
                    </button>

                </form>

            </div>

        </div>

    <% }) %>

</div>
    </section>

    <footer class="footer">


        <div class="footer-container">

            <h2 class="footer-logo">LearnLoop</h2>

            <p class="footer-description">
                A skill-sharing platform where learners become teachers
                and teachers become learners.
            </p>

            <div class="footer-links">
                <a href="/">Home</a>
                <a href="/about">About</a>
                <a href="/register">Register</a>
                <a href="/login">Login</a>
            </div>

        </div>

        <div class="footer-bottom">

            <p class="footer-tagline">
                Learn • Teach • Grow Together
            </p>

            <p class="footer-copy">
                © 2026 LearnLoop | Built using Node.js, Express.js, MongoDB Atlas & EJS
            </p>

        </div>


    </footer>



</body>

</html>